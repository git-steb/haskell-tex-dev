# Version configuration for haskell-tex-dev
# Single source of truth for all version variables
# Aligns with ghcup default channel (https://github.com/haskell/ghcup-metadata) as of 2026-03

# Main project version (from VERSION file in repo root)
VERSION=1.3.0

# Haskell toolchain (GHCup-installable; HLS bindists: see HLS release notes)
GHC_VERSION=9.14.1
CABAL_VERSION=3.16.1.0
HLS_VERSION=2.13.0.0
STACK_VERSION=3.9.3

# Ormolu: install from GitHub release bindist (not cabal install — ghc-lib-parser lags GHC 9.14)
ORMOLU_VERSION=0.8.0.2

# System tool versions (flexible ranges)
NODE_VERSION=20
PYTHON_VERSION=3.12

# WASM GHC (separate from host GHC; optional cross-compiler via ghc-wasm-meta channel)
WASI_SDK_VERSION=20250701T113726
GHC_WASM_VERSION=9.12.2.20250327

# LLVM version (informative; system packages)
LLVM_VERSION=18.1.3

# Python package versions (latest stable)
PYARROW_VERSION=latest
PANDAS_VERSION=latest
NUMPY_VERSION=latest

# TeX Live version
TEXLIVE_VERSION=2023

# Dependency resolution strategy:
# - Core libraries: Open ranges for discoverability
# - Web frameworks: Stable versions for reliability
# - Experimental features: Pinned for reproducibility
